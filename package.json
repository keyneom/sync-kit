      "default": "./dist/keys/web-passkey/index.js"
    },
    "./auth/google-web": {
      "types": "./dist/auth/google-web/index.d.ts",
      "import": "./dist/auth/google-web/index.js",
      "default": "./dist/auth/google-web/index.js"
    },
    "./auth/google-web/identity": {
      "types": "./dist/auth/google-web/identity.d.ts",
      "import": "./dist/auth/google-web/identity.js",
      "default": "./dist/auth/google-web/identity.js"
    },
