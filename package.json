{
  "name": "@keyneom/sync-kit",
  "version": "0.2.0-rc.9",
  "private": false,
  "description": "Provider-neutral encrypted application-data synchronization with opt-in browser adapters.",
  "keywords": [
    "encrypted-sync",
    "google-drive",
    "passkeys",
    "webcrypto"
  ],
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js",
      "default": "./dist/crypto/index.js"
    },
    "./snapshot": {
      "types": "./dist/snapshot/index.d.ts",
      "import": "./dist/snapshot/index.js",
      "default": "./dist/snapshot/index.js"
    },
    "./snapshot/lifecycle": {
      "types": "./dist/snapshot/lifecycle.d.ts",
      "import": "./dist/snapshot/lifecycle.js",
      "default": "./dist/snapshot/lifecycle.js"
    },
    "./sharing": {
      "types": "./dist/sharing/index.d.ts",
      "import": "./dist/sharing/index.js",
      "default": "./dist/sharing/index.js"
    },
    "./sharing/web-crypto": {
      "types": "./dist/sharing/web-crypto.d.ts",
      "import": "./dist/sharing/web-crypto.js",
      "default": "./dist/sharing/web-crypto.js"
    },
    "./sharing/controller": {
      "types": "./dist/sharing/controller.d.ts",
      "import": "./dist/sharing/controller.js",
      "default": "./dist/sharing/controller.js"
    },
    "./sharing/web-passkey": {
      "types": "./dist/sharing/web-passkey.d.ts",
      "import": "./dist/sharing/web-passkey.js",
      "default": "./dist/sharing/web-passkey.js"
    },
    "./sharing/account-binding": {
      "types": "./dist/sharing/account-binding.d.ts",
      "import": "./dist/sharing/account-binding.js",
      "default": "./dist/sharing/account-binding.js"
    },
    "./sharing/appdata-identity-store": {
      "types": "./dist/sharing/appdata-identity-store.d.ts",
      "import": "./dist/sharing/appdata-identity-store.js",
      "default": "./dist/sharing/appdata-identity-store.js"
    },
    "./sharing/migrating-identity-store": {
      "types": "./dist/sharing/migrating-identity-store.d.ts",
